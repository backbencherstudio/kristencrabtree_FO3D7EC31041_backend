generator client {
  provider        = "prisma-client-js"
  previewFeatures = ["fullTextSearchPostgres"]
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Account {
  id         String   @id @default(cuid())
  created_at DateTime @default(now())
  updated_at DateTime @default(now())

  user_id String
  user    User   @relation(fields: [user_id], references: [id], onDelete: Cascade)

  type                String?
  provider            String?
  provider_account_id String?
  refresh_token       String?
  access_token        String?
  expires_at          DateTime?
  token_type          String?
  scope               String?
  id_token            String?
  session_state       String?

  @@unique([provider, provider_account_id])
  @@map("accounts")
}

model User {
  id         String    @id @default(cuid())
  created_at DateTime  @default(now())
  updated_at DateTime  @default(now())
  deleted_at DateTime?
  status     Int?      @default(1) @db.SmallInt // 1=active, 2=suspended, 3=under review

  approved_at  DateTime?
  availability String?

  email      String? @unique
  username   String? @unique
  name       String? @db.VarChar(255)
  first_name String? @db.VarChar(255)
  last_name  String? @db.VarChar(255)
  password   String? @db.VarChar(255)
  domain     String? @unique
  avatar     String?

  phone_number  String?
  country       String?
  state         String?
  city          String?
  address       String?
  zip_code      String?
  gender        String?
  date_of_birth DateTime? @db.Date
  fcm_token     String?
  billing_id    String?   // e.g. Stripe Customer ID

  type              String?   @default("user")
  email_verified_at DateTime?

  is_agrred_to_terms_and_policy Boolean?
  is_two_factor_enabled         Int?     @default(0)
  two_factor_secret             String?
  subscriptionValidUntil        String?
  subscriptionPlan              String?  @default("free")

  firebaseUid String?
  apple_id    String?

  // ── XP & Level ──────────────────────────────────────────────────────────
  currentLevel Int? @default(0)
  acheivedXp   Int? @default(0)
  // XP microcopy (client requirement):
  // "XP reflects your engagement — not your progress."
  // Tooltip: "XP reflects time spent engaging with your inner work — not how well you're doing."

  // ── Days Engaged (client prefers "Days Engaged" over "Day Streak") ──────
  daysEngaged Int? @default(0)

  // ── Relations ────────────────────────────────────────────────────────────
  accounts                  Account[]
  creator_conversations     Conversation[] @relation("creator")
  participant_conversations Conversation[] @relation("participant")
  receiver_messages         Message[]      @relation("receiver")
  sender_messages           Message[]      @relation("sender")
  receiver_notifications    Notification[] @relation("receiver")
  sender_notifications      Notification[] @relation("sender")

  user_payment_methods UserPaymentMethod[]
  user_settings        UserSetting[]
  ucodes               Ucode[]
  roles                Role[]
  role_users           RoleUser[]
  payment_transactions PaymentTransaction[]
  UserPreferences      UserPreferences[]
  quotes               Quote[]
  journels             Journel[]
  comments             Comments[]
  likeJournels         LikeJournel[]
  murmurationLikes     MurmurationLike[]
  commentLikes         CommentLike[]
  murmurations         Murmuration[]
  quoteReactions       QuoteReaction[]
  meditationListeners  MeditationListener[]
  favoriteMeditations  favoriteMeditation[]
  layers               Layers[]
  digs                 Digs[]
  userSubscription     UserSubscription[]
  weeklyDigs           UserWeeklyDig[]
  dailyDigs            UserDailyDig[]
  notificationSettings NotificationSettings?
  digResponses         DigResponse[]
  digProgress          UserDigProgress[]     // ✅ pause/resume tracking
  murmurationBookmarks MurmurationBookmark[]

  @@map("users")
}

// ════════════════════════════════════════════════════════════════════════════
// USER PREFERENCES
// ════════════════════════════════════════════════════════════════════════════

enum Focus_Area {
  Mental_Body
  Emotional_Body
  Physical_Body
  Energy_Body
}

enum Weekly_Practice {
  Light_1_3
  Moderate_4_7
  Deep_4_7
}

enum Frequency {
  DAILY
  WEEKLY
  OCCASIONALLY
}

enum Content_Preference {
  DAILY_WISDOM_QUOTES
  GUIDED_EXERCISES
  MEDITATION_CONTENT
  COMMUNITY_DISCUSSIONS
  JOURNAL_PROMPTS
  SCIENTIFIC_INSIGHTS
}

model UserPreferences {
  id         String    @id @default(cuid())
  created_at DateTime  @default(now())
  updated_at DateTime  @default(now())
  deleted_at DateTime?

  user_id            String?              @unique
  user               User?                @relation(fields: [user_id], references: [id], onDelete: Cascade)
  content_preference Content_Preference[]

  dailyWisdomQuotes    Frequency?
  guidedExercises      Frequency?
  meditationContent    Frequency?
  communityDiscussions Frequency?
  journalPrompts       Frequency?
  scientificInsights   Frequency?
  focus_area           Focus_Area[]
  weekly_practice      Weekly_Practice?

  @@map("user_preferences")
}

// ════════════════════════════════════════════════════════════════════════════
// PLANS & SUBSCRIPTIONS
// ════════════════════════════════════════════════════════════════════════════

model Plans {
  id         String    @id @default(cuid())
  created_at DateTime  @default(now())
  updated_at DateTime  @default(now())
  deleted_at DateTime?

  title       String?
  description String?
  price       String?
  subtitle    String?
  tag         String?
  features    String[]

  stripe_product_id String? @unique
  stripe_price_id   String? @unique

  userSubscriptions UserSubscription[]

  @@map("plans")
}

model UserSubscription {
  id                   String               @id @default(cuid())
  userId               String?              @unique
  stripeSubscriptionId String?              @unique
  paymentTransactions  PaymentTransaction[]
  planName             String?
  planId               String?
  description          String[]
  allowedPermissions   String[]
  timesRenewed         Int?
  status               String?
  cardLast4            String?
  method               String?
  accessId             String?
  user                 User?                @relation(fields: [userId], references: [id])
  created_at           DateTime             @default(now())
  updated_at           DateTime             @default(now())
  plans                Plans?               @relation(fields: [plansId], references: [id])
  plansId              String?
}

model accessForSubscription {
  id               String   @unique
  subscriptionName String?  @unique
  journal_entries  Int?
  quotesPerday     Int?
  digsPerWeek      Int?
  murmurationLimit Boolean?
  audioPostJournal Boolean?
  meditationAccess Boolean?
  adService        Boolean?
  created_at       DateTime @default(now())
  updated_at       DateTime @updatedAt

  @@map("subscription_access")
}

// ════════════════════════════════════════════════════════════════════════════
// AUTH & ROLES
// ════════════════════════════════════════════════════════════════════════════

model Ucode {
  id         String   @id @default(cuid())
  created_at DateTime @default(now())
  updated_at DateTime @default(now())
  status     Int?     @default(1) @db.SmallInt

  user_id String?
  user    User?   @relation(fields: [user_id], references: [id])

  token      String?
  email      String?
  expired_at DateTime?

  @@map("ucodes")
}

model Role {
  id         String    @id @default(cuid())
  created_at DateTime  @default(now())
  updated_at DateTime  @default(now())
  deleted_at DateTime?

  status Int?    @default(1) @db.SmallInt
  title  String?
  name   String?

  user_id String?
  user    User?   @relation(fields: [user_id], references: [id], onDelete: Cascade)

  permission_roles PermissionRole[]
  role_users       RoleUser[]
  permissions      Permission[]     @relation("PermissionToRole")

  @@map("roles")
}

model Permission {
  id         String    @id @default(cuid())
  created_at DateTime  @default(now())
  updated_at DateTime  @default(now())
  deleted_at DateTime?

  status     Int?    @default(1) @db.SmallInt
  title      String?
  action     String?
  subject    String?
  conditions String?
  fields     String?

  permission_roles PermissionRole[]
  roles            Role[]           @relation("PermissionToRole")

  @@map("permissions")
}

model PermissionRole {
  created_at DateTime @default(now())
  updated_at DateTime @default(now())

  permission_id String
  permission    Permission @relation(fields: [permission_id], references: [id], onDelete: Cascade)

  role_id String
  role    Role   @relation(fields: [role_id], references: [id], onDelete: Cascade)

  @@id([permission_id, role_id])
  @@map("permission_roles")
}

model RoleUser {
  created_at DateTime @default(now())
  updated_at DateTime @default(now())

  role_id String
  role    Role   @relation(fields: [role_id], references: [id], onDelete: Cascade)

  user_id String
  user    User   @relation(fields: [user_id], references: [id], onDelete: Cascade)

  @@id([role_id, user_id])
  @@map("role_users")
}

// ════════════════════════════════════════════════════════════════════════════
// NOTIFICATIONS
// ════════════════════════════════════════════════════════════════════════════

model NotificationEvent {
  id         String    @id @default(cuid())
  created_at DateTime  @default(now())
  updated_at DateTime  @default(now())
  deleted_at DateTime?

  status Int?    @default(1) @db.SmallInt
  type   String?
  text   String?

  notifications Notification[]

  @@map("notification_events")
}

model Notification {
  id         String    @id @default(cuid())
  created_at DateTime  @default(now())
  updated_at DateTime  @default(now())
  deleted_at DateTime?

  read_at DateTime?
  status  Int?      @default(1) @db.SmallInt

  sender_id String?
  sender    User?   @relation("sender", fields: [sender_id], references: [id])

  receiver_id String?
  receiver    User?   @relation("receiver", fields: [receiver_id], references: [id])

  notification_event_id String?
  notification_event    NotificationEvent? @relation(fields: [notification_event_id], references: [id])

  entity_id String?

  @@map("notifications")
}

model NotificationSettings {
  id         String   @id @default(cuid())
  created_at DateTime @default(now())
  updated_at DateTime @updatedAt

  user_id String @unique
  user    User   @relation(fields: [user_id], references: [id], onDelete: Cascade)

  // Client requirement: notifications = user-controlled reminders, not activity log
  dig_reminders        Boolean @default(true)  // ✅ renamed from notification_reminder
  meditation_reminders Boolean @default(true)
  new_content_alerts   Boolean @default(true)
  community_updates    Boolean @default(true)
  email_updates        Boolean @default(true)

  @@map("notification_settings")
}

// ════════════════════════════════════════════════════════════════════════════
// PAYMENTS
// ════════════════════════════════════════════════════════════════════════════

model UserPaymentMethod {
  id         String    @id @default(cuid())
  created_at DateTime  @default(now())
  updated_at DateTime  @default(now())
  deleted_at DateTime?

  user_id String?
  user    User?   @relation(fields: [user_id], references: [id])

  payment_method_id String?
  checkout_id       String?

  @@map("user_payment_methods")
}

model PaymentTransaction {
  id         String    @id @default(cuid())
  created_at DateTime  @default(now())
  updated_at DateTime  @default(now())
  deleted_at DateTime?

  store_id String?

  user_id String?
  user    User?   @relation(fields: [user_id], references: [id])

  order_id         String?
  type             String?           @default("order")
  withdraw_via     String?           @default("wallet")
  provider         String?
  reference_number String?
  status           String?           @default("pending")
  raw_status       String?
  amount           Decimal?
  currency         String?
  paid_amount      Decimal?
  paid_currency    String?
  subscriptionId   String?
  subscription     UserSubscription? @relation(fields: [subscriptionId], references: [id])

  @@map("payment_transactions")
}

// ════════════════════════════════════════════════════════════════════════════
// CHAT
// ════════════════════════════════════════════════════════════════════════════

enum MessageStatus {
  PENDING
  SENT
  DELIVERED
  READ
}

model Message {
  id         String    @id @default(cuid())
  created_at DateTime  @default(now())
  updated_at DateTime  @default(now())
  deleted_at DateTime?

  status MessageStatus? @default(PENDING)

  sender_id String?
  sender    User?   @relation("sender", fields: [sender_id], references: [id])

  receiver_id String?
  receiver    User?   @relation("receiver", fields: [receiver_id], references: [id])

  conversation_id String?
  conversation    Conversation? @relation(fields: [conversation_id], references: [id], onDelete: Cascade)

  attachment_id String?
  attachment    Attachment? @relation(fields: [attachment_id], references: [id])

  message String?

  @@map("messages")
}

model Attachment {
  id         String    @id @default(cuid())
  created_at DateTime  @default(now())
  updated_at DateTime  @default(now())
  deleted_at DateTime?

  name     String?
  type     String?
  size     Int?
  file     String?
  file_alt String?

  messages Message[]

  @@map("attachments")
}

model Conversation {
  id         String    @id @default(cuid())
  created_at DateTime  @default(now())
  updated_at DateTime  @default(now())
  deleted_at DateTime?

  creator_id String?
  creator    User?   @relation("creator", fields: [creator_id], references: [id])

  participant_id String?
  participant    User?   @relation("participant", fields: [participant_id], references: [id])

  messages Message[]

  @@map("conversations")
}

// ════════════════════════════════════════════════════════════════════════════
// MISC
// ════════════════════════════════════════════════════════════════════════════

model Faq {
  id         String    @id @default(cuid())
  created_at DateTime  @default(now())
  updated_at DateTime  @default(now())
  deleted_at DateTime?

  status     Int?    @default(1) @db.SmallInt
  sort_order Int?    @default(0)
  question   String?
  answer     String?

  @@map("faqs")
}

model Contact {
  id         String    @id @default(cuid())
  created_at DateTime  @default(now())
  updated_at DateTime  @default(now())
  deleted_at DateTime?

  first_name   String?
  last_name    String?
  email        String?
  phone_number String?
  message      String?

  @@map("contacts")
}

model SocialMedia {
  id         String    @id @default(cuid())
  created_at DateTime  @default(now())
  updated_at DateTime  @default(now())
  deleted_at DateTime?

  status     Int?    @default(1) @db.SmallInt
  sort_order Int?    @default(0)
  name       String?
  url        String?
  icon       String?

  @@map("social_medias")
}

model WebsiteInfo {
  id         String    @id @default(cuid())
  created_at DateTime  @default(now())
  updated_at DateTime  @default(now())
  deleted_at DateTime?

  name                String?
  phone_number        String?
  email               String?
  address             String?
  logo                String?
  favicon             String?
  copyright           String?
  cancellation_policy String?

  @@map("website_infos")
}

model Setting {
  id         String    @id @default(cuid())
  created_at DateTime  @default(now())
  updated_at DateTime  @default(now())
  deleted_at DateTime?

  category      String?
  label         String?
  description   String?
  key           String? @unique
  default_value String?

  user_settings UserSetting[]

  @@map("settings")
}

model UserSetting {
  id         String    @id @default(cuid())
  created_at DateTime  @default(now())
  updated_at DateTime  @default(now())
  deleted_at DateTime?

  user_id String?
  user    User?   @relation(fields: [user_id], references: [id])

  setting_id String?
  setting    Setting? @relation(fields: [setting_id], references: [id])

  value String?

  @@map("user_settings")
}

model Content {
  id         String    @id @default(cuid())
  created_at DateTime  @default(now())
  updated_at DateTime  @default(now())
  deleted_at DateTime?

  status  Int?    @default(1) @db.SmallInt
  title   String?
  body    String? @db.Text
  slug    String? @unique
  excerpt String? @db.Text
  author  String?

  @@map("contents")
}

// ════════════════════════════════════════════════════════════════════════════
// QUOTES
// Client requirements:
// - Admin uploads preloaded quotes
// - Users can add their own quotes
// - Combined randomized pool for display
// - Favorite/like flow
// - Edit and delete for user-added quotes
// ════════════════════════════════════════════════════════════════════════════

model Quote {
  id         String    @id @default(cuid())
  created_at DateTime  @default(now())
  updated_at DateTime  @default(now())
  deleted_at DateTime?

  quote_author String?
  quote_text   String?      @db.Text
  reason       String?      @db.Text
  type         Focus_Area[]
  status       Boolean?     @default(true)

  // source: 'admin' = preloaded by owner, 'user' = added by user
  source  String? @default("admin") // ✅ 'admin' | 'user'

  user_id        String?
  user           User?           @relation(fields: [user_id], references: [id])
  quoteReactions QuoteReaction[]

  @@map("quotes")
}

model QuoteReaction {
  created_at DateTime @default(now())
  updated_at DateTime @default(now())

  userId  String
  qouteId String

  user  User  @relation(fields: [userId], references: [id])
  qoute Quote @relation(fields: [qouteId], references: [id])

  @@id([userId, qouteId])
}

// ════════════════════════════════════════════════════════════════════════════
// JOURNAL
// Client requirements:
// - Text, Audio, Photos
// - Free: text + photo only
// - Paid: audio included
// - Editable, retrievable
// ════════════════════════════════════════════════════════════════════════════

enum JournalType {
  Text
  Audio
  Photo
}

model Journel {
  id         String       @id @default(cuid())
  created_at DateTime     @default(now())
  updated_at DateTime     @default(now())
  deleted_at DateTime?
  type       JournalType?

  title  String?
  body   String?  @db.Text
  audio  String?           // stored as filename only
  photos String[]          // stored as full paths e.g. /journal-photos/file.jpg
  tags   String[]

  user_id      String?
  user         User?         @relation(fields: [user_id], references: [id])
  likeJournels LikeJournel[]

  @@map("journels")
}

model LikeJournel {
  created_at DateTime @default(now())
  updated_at DateTime @default(now())

  userId    String
  journelId String

  user    User    @relation(fields: [userId], references: [id])
  journel Journel @relation(fields: [journelId], references: [id])

  @@id([userId, journelId])
}

// ════════════════════════════════════════════════════════════════════════════
// MURMURATION (Community)
// Client requirements:
// - Lives in app, not website
// - Free users: read-only
// - Paid users: post, reply, react, bookmark
// - Admin can create topics
// - Users can create topics
// - Supportive tone, not social media
// ════════════════════════════════════════════════════════════════════════════

enum MurmurationType {
  Text
  Image
  Audio
}

model Murmuration {
  id         String           @id @default(cuid())
  created_at DateTime         @default(now())
  updated_at DateTime         @updatedAt
  deleted_at DateTime?

  type  MurmurationType?
  title String?

  // ✅ Topic support (client wants topics like "Who Am I", "The Four Bodies")
  topic String?

  user_id String?
  user    User?   @relation(fields: [user_id], references: [id])

  text  String? @db.Text
  image String?
  audio String?

  // ✅ Shared post support
  shared_from_id String?
  shared_from    Murmuration?  @relation("MurmurationShares", fields: [shared_from_id], references: [id])
  shares         Murmuration[] @relation("MurmurationShares")

  comments         Comments[]
  murmurationLikes MurmurationLike[]

  // ✅ Bookmark support (client wants save/bookmark)
  bookmarks MurmurationBookmark[]

  @@map("murmurations")
}

model MurmurationLike {
  userId        String
  murmurationId String

  user        User        @relation(fields: [userId], references: [id])
  murmuration Murmuration @relation(fields: [murmurationId], references: [id])

  @@id([userId, murmurationId])
  @@index([murmurationId])
}

// ✅ NEW — bookmark/save murmuration posts
model MurmurationBookmark {
  id         String   @id @default(cuid())
  created_at DateTime @default(now())

  userId        String
  murmurationId String

  user        User        @relation(fields: [userId], references: [id])
  murmuration Murmuration @relation(fields: [murmurationId], references: [id])

  @@unique([userId, murmurationId])
  @@map("murmuration_bookmarks")
}

model Comments {
  id         String    @id @default(cuid())
  created_at DateTime  @default(now())
  updated_at DateTime  @updatedAt
  deleted_at DateTime?

  user_id String?
  user    User?   @relation(fields: [user_id], references: [id])

  murmuration_id String?
  murmuration    Murmuration? @relation(fields: [murmuration_id], references: [id])

  reply_to_comment_id String?
  reply_to_comment    Comments?  @relation("CommentReplies", fields: [reply_to_comment_id], references: [id])
  comments            Comments[] @relation("CommentReplies")

  body         String?       @db.Text
  commentLikes CommentLike[]

  @@map("comments")
}

model CommentLike {
  userId    String
  commentId String

  user    User     @relation(fields: [userId], references: [id])
  comment Comments @relation(fields: [commentId], references: [id])

  @@id([userId, commentId])
  @@index([commentId])
}

// ✅ Add to User model relation
// bookmarks MurmurationBookmark[]

// ════════════════════════════════════════════════════════════════════════════
// MEDITATION
// Client requirements:
// - Owner-uploaded content only (no affiliate links)
// - MP3 audio + MP4 video support
// - Title, description, content management
// - "Who Am I?" as specific experience
// - Save/favorite meditations
// - Paid users only
// ════════════════════════════════════════════════════════════════════════════

model Meditation {
  id         String    @id @default(cuid())
  created_at DateTime  @default(now())
  updated_at DateTime  @updatedAt
  deleted_at DateTime?

  meditation_name        String?
  meditation_description String?
  meditation_audio       String?  // MP3 — stored as path
  meditation_video       String?  // MP4 — stored as path ✅
  thumbnail              String?  // cover image ✅
  duration               String?
  type                   String?  @default("audio") // 'audio' | 'video' ✅
  is_premium             Boolean  @default(true)    // paid users only ✅

  // ✅ Category tag — e.g. "Who Am I", "Mind Expansion"
  category String?

  // ✅ Sort order for admin control
  sort_order Int? @default(0)

  listeners           MeditationListener[]
  favoriteMeditations favoriteMeditation[]

  @@map("meditation")
}

model MeditationListener {
  userId       String
  meditationId String

  user       User       @relation(fields: [userId], references: [id])
  meditation Meditation @relation(fields: [meditationId], references: [id])

  @@id([userId, meditationId])
  @@index([meditationId])
}

model favoriteMeditation {
  id         String    @id @default(cuid())
  created_at DateTime  @default(now())
  updated_at DateTime  @updatedAt
  deleted_at DateTime?

  user_id String?
  user    User?   @relation(fields: [user_id], references: [id])

  meditation_id String?
  meditation    Meditation? @relation(fields: [meditation_id], references: [id])

  @@map("favorite_meditation")
}

// ════════════════════════════════════════════════════════════════════════════
// DIGS (The Core Experience)
// Client requirements:
// - "Dig" = full container, "Layer" = depth within
// - 4 layers: The Question → Explore → The Experience → Reflect
// - Users can pause at any layer and resume later
// - Free: 3 digs/week, Paid: unlimited
// - XP for engagement (not correctness)
// - Categorized by 4 bodies: Mental, Emotional, Physical, Energy
// ════════════════════════════════════════════════════════════════════════════

model Digs {
  id         String    @id @default(cuid())
  created_at DateTime  @default(now())
  updated_at DateTime  @updatedAt
  deleted_at DateTime?

  title       String
  description String?  // ✅ dig description

  // Categorized by the four bodies (client requirement)
  type Focus_Area[]

  user_id String?
  user    User?   @relation(fields: [user_id], references: [id])

  answeredCount Int? @default(0)

  layers            Layers[]
  digResponses      DigResponse[]
  weeklyAssignments UserWeeklyDig[]
  dailyAssignments  UserDailyDig[]
  userProgress      UserDigProgress[] // ✅ pause/resume

  @@map("digs")
}

// Layer types
enum Type {
  Text
  Option
}

// Layer titles mapped to client language:
// The_Question  = "The Question"  (Layer 1)
// The_Journal   = "Explore"       (Layer 2)
// The_Experience = "The Experience" (Layer 3)
// The_Reflection = "Reflect"      (Layer 4)
enum LayerTitle {
  The_Question
  The_Journal
  The_Experience
  The_Reflection
}

model Layers {
  id         String    @id @default(cuid())
  created_at DateTime  @default(now())
  updated_at DateTime  @updatedAt
  deleted_at DateTime?

  user_id String?
  user    User?   @relation(fields: [user_id], references: [id])

  dig_id String
  dig    Digs   @relation(fields: [dig_id], references: [id], onDelete: Cascade)

  // ✅ Layer number (1-4) for ordering and position display
  layer_number  Int?
  question_name LayerTitle?
  question_type Type?
  point         Int?        // XP points awarded for engagement
  question      String?

  // ✅ Transition message shown after completing this layer
  // Default: "Noticing this is where change begins."
  transition_message String? @default("Noticing this is where change begins.")

  // Layer 1: option-based question
  options        String[]
  other          Boolean? // ✅ always allow "Other" option (client requirement)
  other_text     String?  // placeholder for other text box

  // Layer 2 & 4: journaling/text
  text String?

  // Layer 3: experience/action prompt
  correct_answer String?

  digResponses DigResponse[]

  @@map("layers")
}

model DigResponse {
  id         String   @id @default(cuid())
  dig_id     String
  user_id    String
  layer_id   String
  response   String?
  is_correct Boolean?
  created_at DateTime @default(now())
  updated_at DateTime @default(now()) // ✅ for resume/edit tracking

  dig   Digs   @relation(fields: [dig_id], references: [id])
  layer Layers @relation(fields: [layer_id], references: [id])
  user  User   @relation(fields: [user_id], references: [id])

  // ✅ One response per user per layer per dig
  @@unique([user_id, dig_id, layer_id])
  @@map("dig_responses")
}

// ✅ NEW — Track which layer user paused on (pause/resume support)
// Client requirement: "Users need to be able to pause at any layer, leave,
// and return later to the exact same place."
model UserDigProgress {
  id             String    @id @default(cuid())
  user_id        String
  dig_id         String
  current_layer  Int       @default(1) // which layer they are currently on
  started_at     DateTime  @default(now())
  last_active_at DateTime  @default(now())
  completed      Boolean   @default(false)
  completed_at   DateTime?

  user User @relation(fields: [user_id], references: [id], onDelete: Cascade)
  dig  Digs @relation(fields: [dig_id], references: [id], onDelete: Cascade)

  @@unique([user_id, dig_id])
  @@map("user_dig_progress")
}

model UserWeeklyDig {
  id        String   @id @default(cuid())
  userId    String
  digId     String
  weekStart DateTime
  position  Int      // 1, 2, 3 (reveal order) — free users get 3/week
  completed Boolean  @default(false)

  user User @relation(fields: [userId], references: [id])
  dig  Digs @relation(fields: [digId], references: [id])

  @@unique([userId, digId, weekStart])
  @@index([userId, weekStart, completed])
  @@map("weekly_dig")
}

model UserDailyDig {
  id         String   @id @default(cuid())
  created_at DateTime @default(now())
  updated_at DateTime @updatedAt

  userId         String
  digId          String
  assignedAt     DateTime @default(now())
  dailyDigNumber Int      // position in sequence for paid users (unlimited)
  completed      Boolean  @default(false)

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
  dig  Digs @relation(fields: [digId], references: [id], onDelete: Cascade)

  @@unique([userId, digId])
  @@index([userId, completed])
  @@index([userId, assignedAt])
  @@map("user_daily_digs")
}

// ════════════════════════════════════════════════════════════════════════════
// ADS
// Client requirements:
// - Not banners, not persistent
// - Between Digs only (not between layers)
// - Full-screen/interstitial with X to close
// - Only owner's own products (book, journal, apparel, cards, etc.)
// - Paid users never see ads
// ════════════════════════════════════════════════════════════════════════════

model Ad {
  id         String    @id @default(cuid())
  created_at DateTime  @default(now())
  updated_at DateTime  @updatedAt
  deleted_at DateTime?

  title       String?
  description String?
  image       String?  // ad image path
  link_url    String?  // where it takes the user (book, shop, etc.)
  product_type String? // 'book' | 'journal' | 'apparel' | 'cards' | 'life_calendar' | 'other'

  is_active  Boolean @default(true)
  sort_order Int?    @default(0)

  @@map("ads")
}